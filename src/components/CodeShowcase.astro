---
---

<section class="relative py-12 md:py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal mb-4 text-center">
      <p class="mb-3 text-[13px] font-semibold uppercase tracking-[0.2em] text-[#818cf8]">Native Agent Primitives</p>
      <h2 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">Built for AI, readable by humans</h2>
      <p class="mx-auto max-w-2xl text-base text-[#94a3b8]">
        Every feature is designed so agents produce correct, traceable, auditable software.
      </p>
    </div>

    <div class="reveal mt-10 overflow-hidden rounded-2xl border border-white/[0.06] bg-[#0f1019]/60">
      <div class="flex flex-col lg:flex-row">
        <!-- Tabs (vertical on desktop) -->
        <div class="flex border-b border-white/[0.06] lg:w-72 lg:flex-col lg:border-r lg:border-b-0">
          <button data-tab="contracts" class="showcase-tab group flex items-center gap-3 border-l-0 border-b-2 border-[#818cf8] px-5 py-4 text-left text-sm font-medium text-white transition lg:border-b-0 lg:border-l-4">
            <svg class="h-5 w-5 shrink-0 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <div>
              <span class="block">Contracts</span>
              <span class="block text-[11px] font-normal text-[#94a3b8]">Z3 SMT verification</span>
            </div>
          </button>
          <button data-tab="traceability" class="showcase-tab group flex items-center gap-3 border-l-0 border-b-2 border-transparent px-5 py-4 text-left text-sm font-medium text-[#94a3b8] transition hover:text-white lg:border-b-0 lg:border-l-4">
            <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            <div>
              <span class="block">Traceability</span>
              <span class="block text-[11px] font-normal text-[#94a3b8]">Confidence tracking</span>
            </div>
          </button>
          <button data-tab="intents" class="showcase-tab group flex items-center gap-3 border-l-0 border-b-2 border-transparent px-5 py-4 text-left text-sm font-medium text-[#94a3b8] transition hover:text-white lg:border-b-0 lg:border-l-4">
            <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            <div>
              <span class="block">Intents</span>
              <span class="block text-[11px] font-normal text-[#94a3b8]">Declare, don't code</span>
            </div>
          </button>
        </div>

        <!-- Content panels -->
        <div class="flex-1">
          <!-- Contracts panel -->
          <div data-panel="contracts" class="showcase-panel">
            <div class="border-b border-white/[0.06] bg-[#0a0a0c]/40 px-5 py-2.5">
              <span class="text-[12px] text-[#94a3b8]">Preconditions verified by Z3 SMT solver at compile time</span>
            </div>
            <div class="grid lg:grid-cols-5">
              <pre class="overflow-x-auto p-5 text-[13px] leading-[1.7] lg:col-span-3"><code><span class="text-violet-400">fn</span> <span class="text-blue-300">safe_divide</span>(a: <span class="text-cyan-300">Int</span>, b: <span class="text-cyan-300">Int</span>) <span class="text-slate-500">-&gt;</span> <span class="text-cyan-300">Int</span>
    <span class="text-violet-400">requires</span> {'{'} b <span class="text-slate-400">!=</span> <span class="text-orange-300">0</span> {'}'}
    <span class="text-violet-400">ensures</span>  {'{'} result <span class="text-slate-400">*</span> b <span class="text-slate-400">==</span> a {'}'}
{'{'}
    <span class="text-violet-400">return</span> a <span class="text-slate-400">/</span> b
{'}'}</code></pre>
              <div class="flex flex-col justify-center border-t border-white/[0.06] p-5 lg:col-span-2 lg:border-t-0 lg:border-l">
                <div class="space-y-3">
                  <div class="flex items-center gap-2 rounded-lg bg-emerald-500/[0.08] px-3 py-2">
                    <svg class="h-3.5 w-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-[12px] font-medium text-emerald-300">VERIFIED STATIC</span>
                  </div>
                  <p class="text-[12px] leading-relaxed text-[#94a3b8]">The Z3 solver proves <code class="text-[#818cf8]">b != 0</code> at every call site. Division by zero is impossible.</p>
                  <a href="/docs/guide/contracts/" class="inline-flex items-center gap-1 text-[12px] font-medium text-[#818cf8] transition hover:text-[#a5b4fc]">
                    Learn more
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Traceability panel -->
          <div data-panel="traceability" class="showcase-panel hidden">
            <div class="border-b border-white/[0.06] bg-[#0a0a0c]/40 px-5 py-2.5">
              <span class="text-[12px] text-[#94a3b8]">@confidence below 0.8 blocks compilation until @reviewed_by</span>
            </div>
            <div class="grid lg:grid-cols-5">
              <pre class="overflow-x-auto p-5 text-[13px] leading-[1.7] lg:col-span-3"><code><span class="text-emerald-400">@authored_by</span>(agent: <span class="text-amber-300">"claude"</span>)
<span class="text-emerald-400">@confidence</span>(<span class="text-orange-300">0.95</span>)
<span class="text-violet-400">fn</span> <span class="text-blue-300">validate_token</span>(<span class="text-violet-400">ref</span> token: <span class="text-cyan-300">String</span>) <span class="text-slate-500">-&gt;</span> <span class="text-cyan-300">Bool</span> {'{'}
    <span class="text-violet-400">return</span> token.length() <span class="text-slate-400">&gt;</span> <span class="text-orange-300">0</span>
{'}'}

<span class="text-emerald-400">@authored_by</span>(agent: <span class="text-amber-300">"claude"</span>)
<span class="text-emerald-400">@confidence</span>(<span class="text-orange-300">0.5</span>)
<span class="text-emerald-400">@reviewed_by</span>(human: <span class="text-amber-300">"rafael"</span>)
<span class="text-violet-400">fn</span> <span class="text-blue-300">experimental_auth</span>(<span class="text-violet-400">ref</span> t: <span class="text-cyan-300">String</span>) <span class="text-slate-500">-&gt;</span> <span class="text-cyan-300">Bool</span> {'{'}
    <span class="text-violet-400">return</span> validate_token(t)
{'}'}</code></pre>
              <div class="flex flex-col justify-center border-t border-white/[0.06] p-5 lg:col-span-2 lg:border-t-0 lg:border-l">
                <div class="space-y-3">
                  <div class="flex items-center gap-2 rounded-lg bg-amber-500/[0.08] px-3 py-2">
                    <svg class="h-3.5 w-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
                    <span class="text-[12px] font-medium text-amber-300">REVIEW REQUIRED</span>
                  </div>
                  <p class="text-[12px] leading-relaxed text-[#94a3b8]">Confidence 0.5 triggers E0260. The compiler blocks until a human signs off with <code class="text-[#818cf8]">@reviewed_by</code>.</p>
                  <a href="/docs/guide/agent-traceability/" class="inline-flex items-center gap-1 text-[12px] font-medium text-[#818cf8] transition hover:text-[#a5b4fc]">
                    Learn more
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Intents panel -->
          <div data-panel="intents" class="showcase-panel hidden">
            <div class="border-b border-white/[0.06] bg-[#0a0a0c]/40 px-5 py-2.5">
              <span class="text-[12px] text-[#94a3b8]">Declare what you want — the compiler generates the implementation</span>
            </div>
            <div class="grid lg:grid-cols-5">
              <pre class="overflow-x-auto p-5 text-[13px] leading-[1.7] lg:col-span-3"><code><span class="text-violet-400">intent</span> <span class="text-blue-300">http_server</span> {'{'}
    port: <span class="text-orange-300">8080</span>
    routes: [
        [<span class="text-amber-300">"GET"</span>, <span class="text-amber-300">"/health"</span>, <span class="text-amber-300">"health"</span>],
        [<span class="text-amber-300">"POST"</span>, <span class="text-amber-300">"/users"</span>, <span class="text-amber-300">"create_user"</span>]
    ]
{'}'}

<span class="text-violet-400">fn</span> <span class="text-blue-300">health</span>() <span class="text-slate-500">-&gt;</span> <span class="text-cyan-300">String</span> {'{'}
    <span class="text-violet-400">return</span> <span class="text-amber-300">"OK"</span>
{'}'}</code></pre>
              <div class="flex flex-col justify-center border-t border-white/[0.06] p-5 lg:col-span-2 lg:border-t-0 lg:border-l">
                <div class="space-y-3">
                  <div class="flex items-center gap-2 rounded-lg bg-[#818cf8]/[0.08] px-3 py-2">
                    <svg class="h-3.5 w-3.5 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    <span class="text-[12px] font-medium text-[#a5b4fc]">12 RESOLVERS</span>
                  </div>
                  <p class="text-[12px] leading-relaxed text-[#94a3b8]">Agents declare intent, compiler generates typed boilerplate. HTTP, database, JSON API, cache, and more.</p>
                  <a href="/docs/guide/intents/" class="inline-flex items-center gap-1 text-[12px] font-medium text-[#818cf8] transition hover:text-[#a5b4fc]">
                    Learn more
                    <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.showcase-tab');
    const panels = document.querySelectorAll('.showcase-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;

        tabs.forEach(t => {
          const el = t as HTMLElement;
          el.classList.remove('border-[#818cf8]', 'text-white');
          el.classList.add('border-transparent', 'text-[#94a3b8]');
          const icon = el.querySelector('svg');
          icon?.classList.remove('text-[#818cf8]');
        });

        tab.classList.add('border-[#818cf8]', 'text-white');
        tab.classList.remove('border-transparent', 'text-[#94a3b8]');
        const activeIcon = tab.querySelector('svg');
        activeIcon?.classList.add('text-[#818cf8]');

        panels.forEach(p => {
          if ((p as HTMLElement).dataset.panel === target) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
