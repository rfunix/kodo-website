---
const tools = [
  { name: "VSCode Extension", icon: "code" },
  { name: "REPL", icon: "terminal" },
  { name: "MCP Server", icon: "cpu" },
  { name: "LSP Server", icon: "zap" },
  { name: "CLI Toolchain", icon: "settings" },
];

const stats = [
  { value: "2,400+", label: "Tests passing" },
  { value: "130+", label: "Examples" },
  { value: "v1.4.0", label: "Latest release" },
];
---

<section class="relative py-12 md:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="reveal grid items-center gap-12 lg:grid-cols-2">
      <!-- Left: Tools -->
      <div>
        <p class="mb-3 text-[13px] font-semibold uppercase tracking-[0.2em] text-[#818cf8]">Ecosystem</p>
        <h2 class="mb-5 text-3xl font-bold tracking-tight md:text-4xl" style="font-family: var(--font-display)">Full ecosystem support</h2>
        <p class="mb-8 max-w-lg text-base text-[#94a3b8]">
          Everything you need to build, test, and deploy Kōdo programs. From editor integration to native MCP server support for AI agents.
        </p>

        <div class="flex flex-wrap gap-2.5">
          {tools.map((tool) => (
            <span class="card-hover inline-flex items-center gap-2 rounded-xl bg-[#0f1019]/60 px-4 py-2.5 text-[13px] font-medium text-[#f8fafc]">
              {tool.icon === "code" && <svg class="h-4 w-4 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>}
              {tool.icon === "terminal" && <svg class="h-4 w-4 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
              {tool.icon === "cpu" && <svg class="h-4 w-4 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>}
              {tool.icon === "zap" && <svg class="h-4 w-4 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>}
              {tool.icon === "settings" && <svg class="h-4 w-4 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>}
              {tool.name}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: Stats -->
      <div class="grid grid-cols-3 gap-2 sm:gap-4">
        {stats.map((stat) => (
          <div class="rounded-2xl border border-white/[0.06] bg-[#0f1019]/50 p-3 text-center sm:p-5">
            <p class="mb-1 font-mono text-lg font-bold text-[#f8fafc] sm:text-2xl">{stat.value}</p>
            <p class="text-[12px] text-[#94a3b8]">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
