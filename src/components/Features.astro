---
const features = [
  {
    title: "Linear Ownership",
    description: "own/ref/mut — every value has one owner. Use-after-move (E0240), borrow-escapes-scope (E0241), double-mut-borrow (E0247) caught at compile time.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`,
  },
  {
    title: "Zero Implicit Conversions",
    description: "No silent type coercions. Int stays Int. Agents can't generate subtle type bugs that pass compilation. Every conversion is explicit.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
  {
    title: "Self-Describing Modules",
    description: "Mandatory meta blocks. The compiler rejects modules without a declared purpose — every module is instantly comprehensible by agents and humans.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
  },
  {
    title: "Exhaustive Pattern Matching",
    description: "match on enums with destructuring. The compiler ensures every variant is handled — no missed cases, no fallthrough, no default swallowing bugs.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />`,
  },
  {
    title: "Complete Standard Library",
    description: "Strings, List<T>, Map<K,V>, JSON, HTTP client/server, File I/O, Math, CLI args. Agents can write real programs without external dependencies.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />`,
  },
  {
    title: "Agent-Centric Developer Tools",
    description: "LSP with contract-aware completions and FixPatch code actions. MCP server for native AI integration. REPL for exploration. Multi-file imports.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
  },
];
---

<section class="relative py-16 md:py-20">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-slate-950 via-slate-900/30 to-slate-950"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="reveal mb-6 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-indigo-400">A complete language</p>
      <h2 class="mb-4 text-3xl font-bold md:text-4xl">Built for correctness, not just convenience</h2>
      <p class="mx-auto max-w-2xl text-base text-slate-400">
        Kōdo isn't annotations bolted onto another language. It's a full compiled language with native binary output via Cranelift.
      </p>
    </div>

    <div class="reveal-stagger mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 transition hover:border-indigo-500/30 hover:bg-slate-900/80">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-400">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="mb-2 text-base font-semibold">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-slate-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
