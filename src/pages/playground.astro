---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="dark" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Try Kōdo in your browser — write code, see diagnostics instantly. No install required." />
    <meta property="og:title" content="Kōdo Playground" />
    <meta property="og:description" content="Try Kōdo in your browser — write code, see diagnostics instantly." />
    <meta property="og:image" content="/kodo.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>Playground — Kōdo</title>
  </head>
  <body class="overflow-hidden bg-[#050507] text-[#f8fafc] antialiased" style="font-family: var(--font-body);">
    <div class="flex h-screen flex-col">
      <!-- Header -->
      <header class="flex-shrink-0 border-b border-white/[0.06] bg-[#050507]/80 backdrop-blur-xl">
        <div class="flex items-center justify-between px-4 py-3 sm:px-6">
          <!-- Left: Back + Title -->
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-2 text-[13px] font-medium text-[#94a3b8] transition hover:text-white">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
              <span class="hidden sm:inline">Back</span>
            </a>
            <div class="flex items-center gap-2.5">
              <img src="/kodo.png" alt="Kōdo" class="h-6 w-6 rounded" />
              <h1 class="text-sm font-bold tracking-tight sm:text-base" style="font-family: var(--font-display);">
                Playground
              </h1>
            </div>
          </div>

          <!-- Right: Example selector + Status -->
          <div class="flex items-center gap-3">
            <div id="wasm-status" class="flex items-center gap-1.5">
              <div class="h-2 w-2 animate-pulse rounded-full bg-[#fbbf24]"></div>
              <span class="text-[11px] text-[#94a3b8]">Loading WASM...</span>
            </div>
            <select id="example-select" class="rounded-lg border border-white/[0.08] bg-white/[0.03] px-3 py-1.5 text-[13px] text-[#f8fafc] outline-none transition hover:border-white/[0.15] hover:bg-white/[0.06] focus:border-[#818cf8]/40" style="font-family: var(--font-body);">
              <option value="Hello World">Hello World</option>
              <option value="Fibonacci">Fibonacci</option>
              <option value="Contracts">Contracts</option>
              <option value="Type Error">Type Error</option>
            </select>
          </div>
        </div>
      </header>

      <!-- Main Content: Editor + Diagnostics -->
      <div class="flex min-h-0 flex-1 flex-col lg:flex-row">
        <!-- Editor Panel -->
        <div class="flex min-h-0 flex-1 flex-col border-b border-white/[0.06] lg:border-b-0 lg:border-r">
          <!-- Editor Header -->
          <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-[#f87171]/50"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#fbbf24]/50"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#4ade80]/50"></div>
              <span id="filename-label" class="ml-2 rounded bg-white/[0.05] px-2 py-0.5 text-[11px] text-[#94a3b8]">hello.ko</span>
            </div>
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Editor</span>
          </div>
          <!-- Textarea -->
          <div class="relative min-h-0 flex-1">
            <textarea
              id="editor"
              class="h-full w-full resize-none border-0 bg-[#0a0a0f] p-4 text-[13px] leading-[1.7] text-[#e2e8f0] caret-[#818cf8] outline-none placeholder:text-[#94a3b8]/30 sm:p-5 sm:text-[14px]"
              style="font-family: var(--font-mono); tab-size: 4;"
              spellcheck="false"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              placeholder="Write some Kōdo code..."
            ></textarea>
          </div>
        </div>

        <!-- Diagnostics Panel -->
        <div class="flex min-h-0 flex-1 flex-col lg:max-w-[45%]">
          <!-- Diagnostics Header -->
          <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2">
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Diagnostics</span>
            <div id="error-count-badge" class="hidden items-center gap-1.5 rounded-full bg-[#ef4444]/10 px-2.5 py-0.5">
              <div class="h-1.5 w-1.5 rounded-full bg-[#ef4444]"></div>
              <span id="error-count-text" class="text-[11px] font-medium text-[#ef4444]">0 errors</span>
            </div>
          </div>
          <!-- Diagnostics Content -->
          <div id="diagnostics" class="min-h-0 flex-1 overflow-y-auto p-4 sm:p-5">
            <!-- Loading state -->
            <div id="diag-loading" class="flex flex-col items-center justify-center gap-3 py-16">
              <div class="h-8 w-8 animate-spin rounded-full border-2 border-[#818cf8]/20 border-t-[#818cf8]"></div>
              <p class="text-[13px] text-[#94a3b8]">Loading Kōdo compiler...</p>
            </div>
            <!-- Results appear here -->
            <div id="diag-results" class="hidden"></div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="flex-shrink-0 border-t border-white/[0.06] bg-[#050507]/80 px-4 py-2 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <img src="/kodo.png" alt="Kōdo" class="h-4 w-4 rounded" />
            <span class="text-[11px] text-[#94a3b8]/50">Powered by Kōdo v1.3.1</span>
          </div>
          <span class="text-[11px] text-[#94a3b8]/50">WASM (634KB)</span>
        </div>
      </footer>
    </div>

    <script type="module">
      import init, { check } from '/wasm/kodo_playground.js';

      // ── Examples ──────────────────────────────────
      const EXAMPLES = {
        "Hello World": `module hello {
    meta { purpose: "Hello world", version: "1.0.0" }
    fn main() -> Int {
        println("Hello, Kōdo!")
        return 0
    }
}`,
        "Fibonacci": `module fibonacci {
    meta { purpose: "Fibonacci sequence", version: "1.0.0" }
    fn fib(n: Int) -> Int
        requires { n >= 0 }
    {
        if n <= 1 { return n }
        return fib(n - 1) + fib(n - 2)
    }
    fn main() -> Int {
        print_int(fib(10))
        return 0
    }
}`,
        "Contracts": `module contracts {
    meta { purpose: "Contract verification demo", version: "1.0.0" }
    fn safe_divide(a: Int, b: Int) -> Int
        requires { b != 0 }
        ensures { true }
    {
        return a / b
    }
    fn main() -> Int {
        let result: Int = safe_divide(10, 2)
        print_int(result)
        return 0
    }
}`,
        "Type Error": `module type_error {
    meta { purpose: "Demonstrate type errors", version: "1.0.0" }
    fn main() -> Int {
        let x: Int = "hello"
        return x
    }
}`
      };

      const FILENAMES = {
        "Hello World": "hello.ko",
        "Fibonacci": "fibonacci.ko",
        "Contracts": "contracts.ko",
        "Type Error": "type_error.ko"
      };

      // ── DOM refs ──────────────────────────────────
      const editor = document.getElementById('editor');
      const diagResults = document.getElementById('diag-results');
      const diagLoading = document.getElementById('diag-loading');
      const wasmStatus = document.getElementById('wasm-status');
      const exampleSelect = document.getElementById('example-select');
      const filenameLabel = document.getElementById('filename-label');
      const errorCountBadge = document.getElementById('error-count-badge');
      const errorCountText = document.getElementById('error-count-text');

      let wasmReady = false;
      let debounceTimer = null;

      // ── Initialize WASM ───────────────────────────
      init().then(() => {
        wasmReady = true;
        wasmStatus.innerHTML = `
          <div class="h-2 w-2 rounded-full bg-[#22c55e]"></div>
          <span class="text-[11px] text-[#94a3b8]">Ready</span>
        `;
        diagLoading.classList.add('hidden');
        diagResults.classList.remove('hidden');
        // Run initial check
        runCheck();
      }).catch((err) => {
        wasmStatus.innerHTML = `
          <div class="h-2 w-2 rounded-full bg-[#ef4444]"></div>
          <span class="text-[11px] text-[#ef4444]">Failed to load</span>
        `;
        diagLoading.innerHTML = `
          <div class="rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 p-4">
            <p class="text-[13px] text-[#ef4444]">Failed to load the WASM module.</p>
            <p class="mt-1 text-[12px] text-[#94a3b8]">${err.message || err}</p>
          </div>
        `;
      });

      // ── Load initial example ──────────────────────
      editor.value = EXAMPLES["Hello World"];

      // ── Example selector ──────────────────────────
      exampleSelect.addEventListener('change', () => {
        const name = exampleSelect.value;
        editor.value = EXAMPLES[name] || '';
        filenameLabel.textContent = FILENAMES[name] || 'untitled.ko';
        runCheck();
      });

      // ── Editor input with debounce ────────────────
      editor.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(runCheck, 300);
      });

      // ── Tab key support ───────────────────────────
      editor.addEventListener('keydown', (e) => {
        if (e.key === 'Tab') {
          e.preventDefault();
          const start = editor.selectionStart;
          const end = editor.selectionEnd;
          editor.value = editor.value.substring(0, start) + '    ' + editor.value.substring(end);
          editor.selectionStart = editor.selectionEnd = start + 4;
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(runCheck, 300);
        }
      });

      // ── Run check ─────────────────────────────────
      function runCheck() {
        if (!wasmReady) return;

        const source = editor.value;
        if (!source.trim()) {
          diagResults.innerHTML = `
            <div class="flex flex-col items-center justify-center gap-2 py-16 text-center">
              <span class="text-2xl opacity-30">{ }</span>
              <p class="text-[13px] text-[#94a3b8]/50">Write some code to see diagnostics</p>
            </div>
          `;
          errorCountBadge.classList.add('hidden');
          errorCountBadge.classList.remove('flex');
          return;
        }

        let result;
        try {
          const raw = check(source);
          result = JSON.parse(raw);
        } catch (err) {
          diagResults.innerHTML = renderError('Check failed', err.message || String(err));
          return;
        }

        renderDiagnostics(result);
      }

      // ── Render diagnostics ────────────────────────
      function renderDiagnostics(result) {
        // The check function returns JSON — adapt to whatever schema the WASM uses
        const errors = result.diagnostics || result.errors || [];
        const moduleName = result.module || null;
        const functions = result.functions || [];

        if (errors.length === 0) {
          // Success state
          errorCountBadge.classList.add('hidden');
          errorCountBadge.classList.remove('flex');

          let html = `
            <div class="mb-4 flex items-center gap-2.5 rounded-lg border border-[#22c55e]/20 bg-[#22c55e]/5 px-4 py-3">
              <svg class="h-5 w-5 flex-shrink-0 text-[#22c55e]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[13px] font-medium text-[#22c55e]">Check passed — no errors</span>
            </div>
          `;

          if (moduleName) {
            html += `
              <div class="mb-3 rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Module</div>
                <div class="text-[13px] font-medium text-[#f8fafc]">${escapeHtml(moduleName)}</div>
              </div>
            `;
          }

          if (functions.length > 0) {
            html += `
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Functions</div>
                <div class="flex flex-wrap gap-1.5">
                  ${functions.map(fn => `
                    <span class="rounded-md border border-[#818cf8]/15 bg-[#818cf8]/5 px-2 py-0.5 text-[12px] text-[#818cf8]" style="font-family: var(--font-mono);">${escapeHtml(fn)}()</span>
                  `).join('')}
                </div>
              </div>
            `;
          }

          // Show raw result for debugging / extra info
          if (result.meta) {
            html += `
              <div class="mt-3 rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Meta</div>
                <div class="space-y-1">
                  ${Object.entries(result.meta).map(([k, v]) => `
                    <div class="flex items-center gap-2 text-[12px]">
                      <span class="text-[#94a3b8]">${escapeHtml(k)}:</span>
                      <span class="text-[#f8fafc]">${escapeHtml(String(v))}</span>
                    </div>
                  `).join('')}
                </div>
              </div>
            `;
          }

          diagResults.innerHTML = html;
        } else {
          // Error state
          errorCountBadge.classList.remove('hidden');
          errorCountBadge.classList.add('flex');
          errorCountText.textContent = `${errors.length} error${errors.length !== 1 ? 's' : ''}`;

          let html = `
            <div class="mb-4 flex items-center gap-2.5 rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 px-4 py-3">
              <svg class="h-5 w-5 flex-shrink-0 text-[#ef4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-[13px] font-medium text-[#ef4444]">${errors.length} error${errors.length !== 1 ? 's' : ''} found</span>
            </div>
          `;

          html += `<div class="space-y-3">`;
          for (const err of errors) {
            const code = err.code || err.error_code || '';
            const message = err.message || err.msg || String(err);
            const line = err.line ?? err.span?.start_line ?? null;
            const col = err.column ?? err.span?.start_col ?? null;
            const suggestion = err.suggestion || err.fix || err.help || null;

            html += `
              <div class="rounded-lg border border-[#ef4444]/10 bg-[#ef4444]/[0.03] p-3">
                <div class="flex items-start gap-2">
                  <div class="mt-0.5 flex-shrink-0">
                    <svg class="h-3.5 w-3.5 text-[#ef4444]/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      ${code ? `<span class="rounded bg-[#ef4444]/10 px-1.5 py-0.5 text-[11px] font-bold text-[#ef4444]" style="font-family: var(--font-mono);">${escapeHtml(code)}</span>` : ''}
                      ${line !== null ? `<span class="text-[11px] text-[#94a3b8]/50">line ${line}${col !== null ? `:${col}` : ''}</span>` : ''}
                    </div>
                    <p class="mt-1 text-[13px] leading-relaxed text-[#f8fafc]/80">${escapeHtml(message)}</p>
                    ${suggestion ? `
                      <div class="mt-2 flex items-start gap-1.5 rounded border border-[#818cf8]/10 bg-[#818cf8]/5 px-2.5 py-1.5">
                        <svg class="mt-0.5 h-3 w-3 flex-shrink-0 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-[12px] text-[#818cf8]/80">${escapeHtml(suggestion)}</span>
                      </div>
                    ` : ''}
                  </div>
                </div>
              </div>
            `;
          }
          html += `</div>`;

          diagResults.innerHTML = html;
        }
      }

      function renderError(title, detail) {
        return `
          <div class="rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 p-4">
            <p class="text-[13px] font-medium text-[#ef4444]">${escapeHtml(title)}</p>
            <p class="mt-1 text-[12px] text-[#94a3b8]">${escapeHtml(detail)}</p>
          </div>
        `;
      }

      function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }
    </script>
  </body>
</html>
