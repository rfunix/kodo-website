---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="dark" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Try Kōdo in your browser — write code, see diagnostics instantly. No install required." />
    <meta property="og:title" content="Kōdo Playground" />
    <meta property="og:description" content="Try Kōdo in your browser — write code, see diagnostics instantly." />
    <meta property="og:image" content="/kodo.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>Playground — Kōdo</title>
    <style>
      .kd-keyword { color: #c792ea; }
      .kd-type { color: #82aaff; }
      .kd-annotation { color: #c3e88d; }
      .kd-number { color: #f78c6c; }
      .kd-string { color: #c3e88d; }
      .kd-comment { color: #546e7a; }
      .kd-bool { color: #f78c6c; }
      #highlight-backdrop {
        color: #e2e8f0;
      }
      #highlight-code {
        font-family: inherit;
        font-size: inherit;
        line-height: inherit;
      }
    </style>
  </head>
  <body class="overflow-hidden bg-[#050507] text-[#f8fafc] antialiased" style="font-family: var(--font-body);">
    <div class="flex h-screen flex-col">
      <!-- Header -->
      <header class="flex-shrink-0 border-b border-white/[0.06] bg-[#050507]/80 backdrop-blur-xl">
        <div class="flex items-center justify-between px-4 py-3 sm:px-6">
          <!-- Left: Logo + Title -->
          <div class="flex items-center gap-2.5">
            <a href="/" class="flex items-center gap-2.5 transition hover:opacity-80">
              <img src="/kodo.png" alt="Kōdo" class="h-6 w-6 rounded" />
              <span class="text-sm font-bold tracking-tight sm:text-base" style="font-family: var(--font-display);">Kōdo</span>
            </a>
            <span class="text-[#94a3b8]/40">|</span>
            <h1 class="text-sm font-medium text-[#94a3b8] sm:text-base" style="font-family: var(--font-display);">
              Playground
            </h1>
          </div>

          <!-- Right: Status + Examples toggle -->
          <div class="flex items-center gap-3">
            <div id="wasm-status" class="flex items-center gap-1.5">
              <div class="h-2 w-2 animate-pulse rounded-full bg-[#fbbf24]"></div>
              <span class="text-[11px] text-[#94a3b8]">Loading WASM...</span>
            </div>
            <button id="toggle-examples" class="flex items-center gap-1.5 rounded-lg border border-white/[0.08] bg-white/[0.03] px-3 py-1.5 text-[13px] text-[#f8fafc] transition hover:border-white/[0.15] hover:bg-white/[0.06]" style="font-family: var(--font-body);">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
              Examples
            </button>
          </div>
        </div>
      </header>

      <!-- Examples Sidebar (togglable) -->
      <div id="examples-sidebar" class="hidden border-b border-white/[0.06] bg-[#0a0a0f]">
        <div class="max-h-[40vh] overflow-y-auto px-4 py-3 lg:max-h-[50vh]">
          <div class="grid grid-cols-1 gap-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="examples-grid"></div>
        </div>
      </div>

      <!-- Main Content: Editor + Diagnostics -->
      <div class="flex min-h-0 flex-1 flex-col lg:flex-row">
        <!-- Editor Panel -->
        <div class="flex min-h-0 flex-1 flex-col border-b border-white/[0.06] lg:border-b-0 lg:border-r">
          <!-- Editor Header -->
          <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-[#f87171]/50"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#fbbf24]/50"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-[#4ade80]/50"></div>
              <span id="filename-label" class="ml-2 rounded bg-white/[0.05] px-2 py-0.5 text-[11px] text-[#94a3b8]">hello.ko</span>
            </div>
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Editor</span>
          </div>
          <!-- CodeMirror Editor -->
          <div id="editor-container" class="min-h-0 flex-1 overflow-hidden"></div>
        </div>

        <!-- Diagnostics Panel -->
        <div class="flex min-h-0 flex-1 flex-col lg:max-w-[45%]">
          <!-- Diagnostics Header -->
          <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-2">
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Diagnostics</span>
            <div id="error-count-badge" class="hidden items-center gap-1.5 rounded-full bg-[#ef4444]/10 px-2.5 py-0.5">
              <div class="h-1.5 w-1.5 rounded-full bg-[#ef4444]"></div>
              <span id="error-count-text" class="text-[11px] font-medium text-[#ef4444]">0 errors</span>
            </div>
          </div>
          <!-- Diagnostics Content -->
          <div id="diagnostics" class="min-h-0 flex-1 overflow-y-auto p-4 sm:p-5">
            <!-- Loading state -->
            <div id="diag-loading" class="flex flex-col items-center justify-center gap-3 py-16">
              <div class="h-8 w-8 animate-spin rounded-full border-2 border-[#818cf8]/20 border-t-[#818cf8]"></div>
              <p class="text-[13px] text-[#94a3b8]">Loading Kōdo compiler...</p>
            </div>
            <!-- Results appear here -->
            <div id="diag-results" class="hidden"></div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="flex-shrink-0 border-t border-white/[0.06] bg-[#050507]/80 px-4 py-2 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <img src="/kodo.png" alt="Kōdo" class="h-4 w-4 rounded" />
            <span class="text-[11px] text-[#94a3b8]/50">Powered by Kōdo v1.3.1</span>
          </div>
          <span class="text-[11px] text-[#94a3b8]/50">WASM (634KB)</span>
        </div>
      </footer>
    </div>

    <script>
      // CodeMirror imports (bundled by Astro/Vite)
      import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightSpecialChars } from '@codemirror/view';
      import { EditorState } from '@codemirror/state';
      import { defaultKeymap, indentWithTab } from '@codemirror/commands';
      import { HighlightStyle, syntaxHighlighting, StreamLanguage } from '@codemirror/language';
      import { tags } from '@lezer/highlight';

      // ── Examples organized by category ──────────
      const EXAMPLES = [
        { category: "Basics", items: [
          { name: "Hello World", file: "hello.ko", hasError: false, code: `module hello {
    meta { purpose: "Hello world", version: "1.0.0" }
    fn main() -> Int {
        println("Hello, Kōdo!")
        return 0
    }
}` },
          { name: "Variables & Expressions", file: "expressions.ko", hasError: false, code: `module expressions {
    meta { purpose: "Variables and expressions", version: "1.0.0" }
    fn main() -> Int {
        let x: Int = 10
        let y: Int = 20
        let sum: Int = x + y
        let product: Int = x * y
        print_int(sum)
        print_int(product)
        return 0
    }
}` },
          { name: "Control Flow", file: "control_flow.ko", hasError: false, code: `module control_flow {
    meta { purpose: "If/else and while loops", version: "1.0.0" }
    fn abs(x: Int) -> Int {
        if x < 0 {
            return 0 - x
        } else {
            return x
        }
    }
    fn main() -> Int {
        print_int(abs(-42))
        let mut i: Int = 0
        while i < 5 {
            print_int(i)
            i = i + 1
        }
        return 0
    }
}` },
          { name: "Fibonacci", file: "fibonacci.ko", hasError: false, code: `module fibonacci {
    meta { purpose: "Fibonacci sequence", version: "1.0.0" }
    fn fib(n: Int) -> Int
        requires { n >= 0 }
    {
        if n <= 1 { return n }
        return fib(n - 1) + fib(n - 2)
    }
    fn main() -> Int {
        print_int(fib(10))
        return 0
    }
}` },
        ]},
        { category: "Type System", items: [
          { name: "Structs & Enums", file: "structs.ko", hasError: false, code: `module shapes {
    meta { purpose: "Structs and enums", version: "1.0.0" }
    struct Point { x: Int, y: Int }
    enum Color { Red, Green, Blue }
    fn distance(ref p: Point) -> Int {
        return p.x * p.x + p.y * p.y
    }
    fn main() -> Int {
        let p: Point = Point { x: 3, y: 4 }
        print_int(distance(p))
        return 0
    }
}` },
          { name: "Generics", file: "generics.ko", hasError: false, code: `module generics {
    meta { purpose: "Generic functions", version: "1.0.0" }
    fn identity(x: Int) -> Int {
        return x
    }
    fn max(a: Int, b: Int) -> Int {
        if a > b { return a }
        return b
    }
    fn main() -> Int {
        print_int(max(10, 20))
        return 0
    }
}` },
          { name: "Pattern Matching", file: "matching.ko", hasError: false, code: `module matching {
    meta { purpose: "Pattern matching", version: "1.0.0" }
    enum Shape { Circle(Int), Rectangle(Int, Int) }
    fn area(ref s: Shape) -> Int {
        match s {
            Shape::Circle(r) => { return r * r * 3 }
            Shape::Rectangle(w, h) => { return w * h }
        }
    }
    fn main() -> Int {
        let c: Shape = Shape::Circle(5)
        let r: Shape = Shape::Rectangle(3, 4)
        print_int(area(c))
        print_int(area(r))
        return 0
    }
}` },
          { name: "Closures", file: "closures.ko", hasError: false, code: `module closures {
    meta { purpose: "Closures and HOF", version: "1.0.0" }
    fn apply(x: Int, f: (Int) -> Int) -> Int {
        return f(x)
    }
    fn main() -> Int {
        let doubled: Int = apply(21, |x: Int| -> Int { x * 2 })
        print_int(doubled)
        return 0
    }
}` },
        ]},
        { category: "Contracts & Safety", items: [
          { name: "Preconditions", file: "contracts.ko", hasError: false, code: `module contracts {
    meta { purpose: "Contract verification", version: "1.0.0" }
    fn safe_divide(a: Int, b: Int) -> Int
        requires { b != 0 }
        ensures { true }
    {
        return a / b
    }
    fn main() -> Int {
        let result: Int = safe_divide(10, 2)
        print_int(result)
        return 0
    }
}` },
          { name: "Agent Traceability", file: "traceability.ko", hasError: false, code: `module traceability {
    meta { purpose: "Agent annotations", version: "1.0.0" }
    @authored_by(agent: "claude", session: "demo")
    @confidence(0.95)
    fn compute(x: Int) -> Int
        requires { x > 0 }
    {
        return x * x
    }
    fn main() -> Int {
        print_int(compute(7))
        return 0
    }
}` },
          { name: "Ownership", file: "ownership.ko", hasError: false, code: `module ownership {
    meta { purpose: "Ownership semantics", version: "1.0.0" }
    struct Data { value: Int }
    fn consume(own d: Data) -> Int {
        return d.value
    }
    fn inspect(ref d: Data) -> Int {
        return d.value
    }
    fn main() -> Int {
        let d: Data = Data { value: 42 }
        let v: Int = inspect(d)
        print_int(v)
        let final: Int = consume(d)
        print_int(final)
        return 0
    }
}` },
        ]},
        { category: "Functions & Data", items: [
          { name: "String Interpolation", file: "strings.ko", hasError: false, code: `module strings {
    meta { purpose: "F-strings and string ops", version: "1.0.0" }
    fn greet(ref name: String) -> String {
        return f"Hello, {name}!"
    }
    fn main() -> Int {
        let msg: String = greet("Kōdo")
        println(msg)
        let n: Int = 42
        println(f"The answer is {n}")
        return 0
    }
}` },
          { name: "Option & Result", file: "option.ko", hasError: false, code: `module error_handling {
    meta { purpose: "Option and Result types", version: "1.0.0" }
    fn safe_get(idx: Int) -> Option<Int> {
        if idx >= 0 {
            return Option::Some(idx * 10)
        }
        return Option::None
    }
    fn main() -> Int {
        let val: Option<Int> = safe_get(3)
        match val {
            Option::Some(x) => { print_int(x) }
            Option::None => { println("not found") }
        }
        return 0
    }
}` },
          { name: "Methods (impl)", file: "methods.ko", hasError: false, code: `module shapes {
    meta { purpose: "Inherent methods", version: "1.0.0" }
    struct Circle { radius: Int }
    struct Rect { w: Int, h: Int }
    impl Circle {
        fn area(self) -> Int {
            return self.radius * self.radius * 3
        }
    }
    impl Rect {
        fn area(self) -> Int {
            return self.w * self.h
        }
    }
    fn main() -> Int {
        let c: Circle = Circle { radius: 5 }
        let r: Rect = Rect { w: 3, h: 4 }
        print_int(c.area())
        print_int(r.area())
        return 0
    }
}` },
          { name: "For-in Loops", file: "for_in.ko", hasError: false, code: `module iteration {
    meta { purpose: "For-in iteration", version: "1.0.0" }
    fn main() -> Int {
        let nums: List<Int> = list_new()
        list_push(nums, 10)
        list_push(nums, 20)
        list_push(nums, 30)
        let mut total: Int = 0
        for x in nums {
            total = total + x
        }
        print_int(total)
        let evens: List<Int> = nums.filter(|x: Int| -> Bool { x > 15 })
        print_int(evens.length())
        return 0
    }
}` },
        ]},
        { category: "Testing", items: [
          { name: "Built-in Tests", file: "testing.ko", hasError: false, code: `module math_tests {
    meta { purpose: "Built-in test framework", version: "1.0.0" }

    fn add(a: Int, b: Int) -> Int
        requires { a >= 0 }
        requires { b >= 0 }
    {
        return a + b
    }

    fn multiply(a: Int, b: Int) -> Int {
        return a * b
    }

    test "add returns correct sum" {
        assert(add(2, 3) == 5)
    }

    test "add with zero" {
        assert(add(0, 42) == 42)
    }

    test "multiply basics" {
        assert(multiply(3, 4) == 12)
        assert(multiply(0, 100) == 0)
    }

    fn main() -> Int {
        return 0
    }
}` },
        ]},
        { category: "Collections", items: [
          { name: "List Operations", file: "lists.ko", hasError: false, code: `module lists {
    meta { purpose: "List operations", version: "1.0.0" }
    fn main() -> Int {
        let nums: List<Int> = list_new()
        list_push(nums, 10)
        list_push(nums, 20)
        list_push(nums, 30)
        let doubled: List<Int> = nums.map(|x: Int| -> Int { x * 2 })
        let total: Int = doubled.fold(0, |acc: Int, x: Int| -> Int { acc + x })
        print_int(total)
        return 0
    }
}` },
          { name: "Set Operations", file: "sets.ko", hasError: false, code: `module sets {
    meta { purpose: "Set operations", version: "1.0.0" }
    fn main() -> Int {
        let a: Set<Int> = set_new()
        a.add(1)
        a.add(2)
        a.add(3)
        let b: Set<Int> = set_new()
        b.add(2)
        b.add(3)
        b.add(4)
        let u: Set<Int> = a.union(b)
        print_int(u.length())
        let i: Set<Int> = a.intersection(b)
        print_int(i.length())
        return 0
    }
}` },
        ]},
        { category: "AI Agent Features", items: [
          { name: "Confidence Tracking", file: "confidence.ko", hasError: false, code: `module ai_pipeline {
    meta {
        purpose: "AI agent confidence tracking"
        version: "1.0.0"
    }

    @authored_by(agent: "claude", session: "s-2026-03")
    @confidence(0.95)
    fn validate_input(x: Int) -> Bool
        requires { x >= 0 }
    {
        return x < 1000
    }

    @authored_by(agent: "claude", session: "s-2026-03")
    @confidence(0.85)
    fn process(x: Int) -> Int
        requires { x >= 0 }
        ensures { true }
    {
        return x * 2 + 1
    }

    // Effective confidence of main is min(0.95, 0.85) = 0.85
    // because it calls both functions
    fn main() -> Int {
        let input: Int = 42
        if validate_input(input) {
            print_int(process(input))
        }
        return 0
    }
}` },
          { name: "Reviewed by Human", file: "reviewed.ko", hasError: false, code: `module reviewed_code {
    meta {
        purpose: "Low confidence code approved by human review"
        version: "1.0.0"
    }

    // confidence 0.6 is below 0.8 threshold
    // but @reviewed_by satisfies the compiler
    @authored_by(agent: "gpt-4", session: "exp-001")
    @confidence(0.6)
    @reviewed_by(human: "rafael")
    fn experimental_algo(x: Int) -> Int
        requires { x > 0 }
    {
        return (x * 31 + 17) % 100
    }

    @authored_by(agent: "claude", session: "s-2026")
    @confidence(0.95)
    fn main() -> Int {
        print_int(experimental_algo(42))
        return 0
    }
}` },
          { name: "Low Confidence (error)", file: "low_conf.ko", hasError: true, code: `module low_confidence {
    meta {
        purpose: "Low confidence without review"
        version: "1.0.0"
    }

    // ERROR: confidence < 0.8 requires @reviewed_by
    @authored_by(agent: "gpt-4")
    @confidence(0.5)
    fn risky_function(x: Int) -> Int {
        return x * x
    }

    fn main() -> Int {
        return risky_function(5)
    }
}` },
          { name: "Security Sensitive (error)", file: "security.ko", hasError: true, code: `module security {
    meta {
        purpose: "Security-sensitive without contracts"
        version: "1.0.0"
    }

    // ERROR: @security_sensitive requires contracts
    @security_sensitive
    fn handle_payment(amount: Int) -> Int {
        return amount
    }

    fn main() -> Int {
        return handle_payment(100)
    }
}` },
          { name: "Self-Describing Module", file: "self_desc.ko", hasError: false, code: `module data_processor {
    meta {
        purpose: "Transform and validate data records"
        version: "2.1.0"
        author: "engineering-team"
    }

    @authored_by(agent: "claude", session: "sprint-42")
    @confidence(0.92)
    fn transform(raw: Int) -> Int
        requires { raw > 0 }
        ensures { true }
    {
        return raw * 10
    }

    @authored_by(agent: "claude", session: "sprint-42")
    @confidence(0.95)
    @reviewed_by(human: "rafael")
    fn validate(value: Int) -> Bool
        requires { value >= 0 }
    {
        return value < 10000
    }

    fn main() -> Int {
        let raw: Int = 42
        let processed: Int = transform(raw)
        if validate(processed) {
            print_int(processed)
        }
        return 0
    }
}` },
          { name: "Missing Meta (error)", file: "no_meta.ko", hasError: true, code: `module forgot_meta {
    // ERROR: every module MUST have a meta block
    // This is how Kōdo enforces self-describing code
    fn main() -> Int {
        return 42
    }
}` },
        ]},
        { category: "Common Errors", items: [
          { name: "Type Mismatch", file: "type_error.ko", hasError: true, code: `module type_error {
    meta { purpose: "Type mismatch", version: "1.0.0" }
    fn main() -> Int {
        // ERROR: String assigned to Int variable
        let x: Int = "hello"
        return x
    }
}` },
          { name: "Use After Move", file: "moved.ko", hasError: true, code: `module moved {
    meta { purpose: "Use after move", version: "1.0.0" }
    struct Data { value: Int }

    fn consume(own d: Data) -> Int {
        return d.value
    }

    fn main() -> Int {
        let d: Data = Data { value: 1 }
        let a: Int = consume(d)
        // ERROR: d was moved into consume()
        let b: Int = consume(d)
        return a + b
    }
}` },
          { name: "Arity Mismatch", file: "arity.ko", hasError: true, code: `module arity {
    meta { purpose: "Wrong argument count", version: "1.0.0" }
    fn add(a: Int, b: Int) -> Int {
        return a + b
    }
    fn main() -> Int {
        // ERROR: add expects 2 args, got 3
        let result: Int = add(1, 2, 3)
        return result
    }
}` },
          { name: "Undefined Variable", file: "undefined.ko", hasError: true, code: `module undefined_var {
    meta { purpose: "Undefined variable", version: "1.0.0" }
    fn main() -> Int {
        // ERROR: unknown_variable not declared
        return unknown_variable
    }
}` },
        ]},
      ];

      // Build flat lookup and filenames
      const EXAMPLE_MAP = {};
      const FILENAMES = {};
      for (const cat of EXAMPLES) {
        for (const item of cat.items) {
          EXAMPLE_MAP[item.name] = item.code;
          FILENAMES[item.name] = item.file;
        }
      }

      // ── Kōdo language definition for CodeMirror ───
      const kodoLanguage = StreamLanguage.define({
        startState: () => ({ inString: false, inComment: false }),
        token(stream, state) {
          if (stream.match(/\/\/.*/)) return 'lineComment';
          if (stream.match(/"(?:[^"\\]|\\.)*"/)) return 'string';
          if (stream.match(/@\w+/)) return 'meta';
          if (stream.match(/\b\d+(?:\.\d+)?\b/)) return 'number';
          if (stream.match(/\b(?:module|meta|fn|let|mut|if|else|while|for|in|return|match|struct|enum|trait|impl|pub|test|describe|requires|ensures|spawn|async|await|import|from|own|ref|is|break|continue|setup|teardown|forall)\b/))
            return 'keyword';
          if (stream.match(/\b(?:Int|Int8|Int16|Int32|Int64|Uint|Uint8|Uint16|Uint32|Uint64|Float32|Float64|Bool|String|Unit|Byte|List|Map|Set|Option|Result|Channel)\b/))
            return 'typeName';
          if (stream.match(/\b(?:true|false)\b/)) return 'bool';
          if (stream.match(/[a-zA-Z_]\w*/)) return 'variableName';
          if (stream.match(/[{}()\[\]<>,:;=+\-*\/%!&|.?]/)) return 'punctuation';
          stream.next();
          return null;
        },
      });

      const kodoHighlight = HighlightStyle.define([
        { tag: tags.keyword, color: '#c792ea' },
        { tag: tags.typeName, color: '#82aaff' },
        { tag: tags.string, color: '#c3e88d' },
        { tag: tags.number, color: '#f78c6c' },
        { tag: tags.bool, color: '#f78c6c' },
        { tag: tags.lineComment, color: '#546e7a' },
        { tag: tags.meta, color: '#ffcb6b' },
        { tag: tags.variableName, color: '#e2e8f0' },
        { tag: tags.punctuation, color: '#89ddff' },
      ]);

      const kodoTheme = EditorView.theme({
        '&': { height: '100%', backgroundColor: '#0a0a0f', fontSize: '13px' },
        '&.cm-focused': { outline: 'none' },
        '.cm-content': { fontFamily: 'JetBrains Mono, monospace', padding: '16px 20px', caretColor: '#818cf8' },
        '.cm-line': { lineHeight: '1.7' },
        '.cm-gutters': { backgroundColor: '#0a0a0f', color: '#94a3b8', border: 'none', borderRight: '1px solid rgba(255,255,255,0.04)' },
        '.cm-gutter.cm-lineNumbers .cm-gutterElement': { padding: '0 8px 0 16px', fontSize: '11px', minWidth: '32px' },
        '.cm-activeLineGutter': { backgroundColor: 'rgba(255,255,255,0.03)' },
        '.cm-activeLine': { backgroundColor: 'rgba(255,255,255,0.02)' },
        '.cm-cursor': { borderLeftColor: '#818cf8', borderLeftWidth: '2px' },
        '.cm-selectionBackground': { backgroundColor: 'rgba(129,140,248,0.2) !important' },
        '&.cm-focused .cm-selectionBackground': { backgroundColor: 'rgba(129,140,248,0.3) !important' },
        '.cm-matchingBracket': { color: '#f8fafc !important', backgroundColor: 'rgba(129,140,248,0.15)' },
      }, { dark: true });

      // ── Create CodeMirror editor ────────────────────
      const editorContainer = document.getElementById('editor-container');
      let editorView = new EditorView({
        state: EditorState.create({
          doc: EXAMPLE_MAP["Hello World"],
          extensions: [
            lineNumbers(),
            highlightActiveLine(),
            highlightSpecialChars(),
            keymap.of([...defaultKeymap, indentWithTab]),
            kodoLanguage,
            syntaxHighlighting(kodoHighlight),
            kodoTheme,
            EditorView.updateListener.of((update) => {
              if (update.docChanged) {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(runCheck, 300);
              }
            }),
          ],
        }),
        parent: editorContainer,
      });

      // ── DOM refs ────────────────────────────────────
      const diagResults = document.getElementById('diag-results');
      const diagLoading = document.getElementById('diag-loading');
      const wasmStatus = document.getElementById('wasm-status');
      const filenameLabel = document.getElementById('filename-label');
      const errorCountBadge = document.getElementById('error-count-badge');
      const errorCountText = document.getElementById('error-count-text');
      const toggleBtn = document.getElementById('toggle-examples');
      const sidebar = document.getElementById('examples-sidebar');
      const examplesGrid = document.getElementById('examples-grid');

      // ── Build examples grid ─────────────────────────
      let selectedExample = "Hello World";
      function buildExamplesGrid() {
        let html = '';
        for (const cat of EXAMPLES) {
          html += `<div class="col-span-full mb-1 mt-2 first:mt-0"><span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/50">${cat.category}</span></div>`;
          for (const item of cat.items) {
            const isActive = item.name === selectedExample;
            const activeCls = isActive ? 'border-[#818cf8]/40 bg-[#818cf8]/10' : 'border-white/[0.06] bg-white/[0.02] hover:border-white/[0.12] hover:bg-white/[0.04]';
            const icon = item.hasError
              ? '<span class="text-[#ef4444]">&#x2717;</span>'
              : '<span class="text-[#22c55e]">&#x2713;</span>';
            html += `<button data-example="${item.name}" class="example-btn flex items-center gap-2 rounded-lg border ${activeCls} px-3 py-2 text-left text-[12px] transition" style="font-family: var(--font-body);">
              <span class="flex-shrink-0 text-[11px]">${icon}</span>
              <span class="truncate text-[#f8fafc]">${item.name}</span>
            </button>`;
          }
        }
        examplesGrid.innerHTML = html;

        // Attach click handlers
        for (const btn of document.querySelectorAll('.example-btn')) {
          btn.addEventListener('click', () => {
            const name = btn.dataset.example;
            selectedExample = name;
            editorView.dispatch({
              changes: { from: 0, to: editorView.state.doc.length, insert: EXAMPLE_MAP[name] || '' }
            });
            filenameLabel.textContent = FILENAMES[name] || 'untitled.ko';
            buildExamplesGrid();
            runCheck();
          });
        }
      }
      buildExamplesGrid();

      // ── Toggle examples sidebar ─────────────────────
      toggleBtn.addEventListener('click', () => {
        sidebar.classList.toggle('hidden');
      });

      let wasmReady = false;
      let wasmCheck = null;
      let debounceTimer = null;

      // ── Initialize WASM ───────────────────────────
      // Poll for WASM module loaded by the inline script below
      async function initWasm() {
        // Wait for the inline script to load and set globalThis.__kodoWasm
        for (let i = 0; i < 200; i++) {
          if (globalThis.__kodoWasm) break;
          await new Promise(r => setTimeout(r, 50));
        }
        if (!globalThis.__kodoWasm) throw new Error('WASM module did not load within 10s');
        wasmCheck = globalThis.__kodoWasm.check;
        wasmReady = true;
        wasmStatus.innerHTML = `
          <div class="h-2 w-2 rounded-full bg-[#22c55e]"></div>
          <span class="text-[11px] text-[#94a3b8]">Ready</span>
        `;
        diagLoading.classList.add('hidden');
        diagResults.classList.remove('hidden');
        runCheck();
      }
      initWasm().catch((err) => {
        wasmStatus.innerHTML = `
          <div class="h-2 w-2 rounded-full bg-[#ef4444]"></div>
          <span class="text-[11px] text-[#ef4444]">Failed to load</span>
        `;
        diagLoading.innerHTML = `
          <div class="rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 p-4">
            <p class="text-[13px] text-[#ef4444]">Failed to load the WASM module.</p>
            <p class="mt-1 text-[12px] text-[#94a3b8]">${err.message || err}</p>
          </div>
        `;
      });

      // CodeMirror handles input, tab, and initial content automatically.

      // ── Run check ─────────────────────────────────
      function runCheck() {
        if (!wasmReady) return;

        const source = editorView.state.doc.toString();
        if (!source.trim()) {
          diagResults.innerHTML = `
            <div class="flex flex-col items-center justify-center gap-2 py-16 text-center">
              <span class="text-2xl opacity-30">{ }</span>
              <p class="text-[13px] text-[#94a3b8]/50">Write some code to see diagnostics</p>
            </div>
          `;
          errorCountBadge.classList.add('hidden');
          errorCountBadge.classList.remove('flex');
          return;
        }

        let result;
        try {
          const raw = wasmCheck(source);
          result = JSON.parse(raw);
        } catch (err) {
          diagResults.innerHTML = renderError('Check failed', err.message || String(err));
          return;
        }

        renderDiagnostics(result);
      }

      // ── Render diagnostics ────────────────────────
      function renderDiagnostics(result) {
        // The check function returns JSON — adapt to whatever schema the WASM uses
        const errors = result.diagnostics || result.errors || [];
        const moduleName = result.module || null;
        const functions = result.functions || [];

        if (errors.length === 0) {
          // Success state
          errorCountBadge.classList.add('hidden');
          errorCountBadge.classList.remove('flex');

          let html = `
            <div class="mb-4 flex items-center gap-2.5 rounded-lg border border-[#22c55e]/20 bg-[#22c55e]/5 px-4 py-3">
              <svg class="h-5 w-5 flex-shrink-0 text-[#22c55e]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[13px] font-medium text-[#22c55e]">Check passed — no errors</span>
            </div>
          `;

          if (moduleName) {
            html += `
              <div class="mb-3 rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Module</div>
                <div class="text-[13px] font-medium text-[#f8fafc]">${escapeHtml(moduleName)}</div>
              </div>
            `;
          }

          if (functions.length > 0) {
            html += `
              <div class="rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Functions</div>
                <div class="flex flex-wrap gap-1.5">
                  ${functions.map(fn => `
                    <span class="rounded-md border border-[#818cf8]/15 bg-[#818cf8]/5 px-2 py-0.5 text-[12px] text-[#818cf8]" style="font-family: var(--font-mono);">${escapeHtml(fn)}()</span>
                  `).join('')}
                </div>
              </div>
            `;
          }

          // Show raw result for debugging / extra info
          if (result.meta) {
            html += `
              <div class="mt-3 rounded-lg border border-white/[0.06] bg-white/[0.02] p-3">
                <div class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-[#94a3b8]/40">Meta</div>
                <div class="space-y-1">
                  ${Object.entries(result.meta).map(([k, v]) => `
                    <div class="flex items-center gap-2 text-[12px]">
                      <span class="text-[#94a3b8]">${escapeHtml(k)}:</span>
                      <span class="text-[#f8fafc]">${escapeHtml(String(v))}</span>
                    </div>
                  `).join('')}
                </div>
              </div>
            `;
          }

          diagResults.innerHTML = html;
        } else {
          // Error state
          errorCountBadge.classList.remove('hidden');
          errorCountBadge.classList.add('flex');
          errorCountText.textContent = `${errors.length} error${errors.length !== 1 ? 's' : ''}`;

          let html = `
            <div class="mb-4 flex items-center gap-2.5 rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 px-4 py-3">
              <svg class="h-5 w-5 flex-shrink-0 text-[#ef4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-[13px] font-medium text-[#ef4444]">${errors.length} error${errors.length !== 1 ? 's' : ''} found</span>
            </div>
          `;

          html += `<div class="space-y-3">`;
          for (const err of errors) {
            const code = err.code || err.error_code || '';
            const message = err.message || err.msg || String(err);
            const line = err.line ?? err.span?.start_line ?? null;
            const col = err.column ?? err.span?.start_col ?? null;
            const suggestion = err.suggestion || err.fix || err.help || null;

            html += `
              <div class="rounded-lg border border-[#ef4444]/10 bg-[#ef4444]/[0.03] p-3">
                <div class="flex items-start gap-2">
                  <div class="mt-0.5 flex-shrink-0">
                    <svg class="h-3.5 w-3.5 text-[#ef4444]/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      ${code ? `<span class="rounded bg-[#ef4444]/10 px-1.5 py-0.5 text-[11px] font-bold text-[#ef4444]" style="font-family: var(--font-mono);">${escapeHtml(code)}</span>` : ''}
                      ${line !== null ? `<span class="text-[11px] text-[#94a3b8]/50">line ${line}${col !== null ? `:${col}` : ''}</span>` : ''}
                    </div>
                    <p class="mt-1 text-[13px] leading-relaxed text-[#f8fafc]/80">${escapeHtml(message)}</p>
                    ${suggestion ? `
                      <div class="mt-2 flex items-start gap-1.5 rounded border border-[#818cf8]/10 bg-[#818cf8]/5 px-2.5 py-1.5">
                        <svg class="mt-0.5 h-3 w-3 flex-shrink-0 text-[#818cf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-[12px] text-[#818cf8]/80">${escapeHtml(suggestion)}</span>
                      </div>
                    ` : ''}
                  </div>
                </div>
              </div>
            `;
          }
          html += `</div>`;

          diagResults.innerHTML = html;
        }
      }

      function renderError(title, detail) {
        return `
          <div class="rounded-lg border border-[#ef4444]/20 bg-[#ef4444]/5 p-4">
            <p class="text-[13px] font-medium text-[#ef4444]">${escapeHtml(title)}</p>
            <p class="mt-1 text-[12px] text-[#94a3b8]">${escapeHtml(detail)}</p>
          </div>
        `;
      }

      function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      // Syntax highlighting is handled by CodeMirror with the kodoLanguage definition.
    </script>
    <script is:inline type="module">
      import init, { check } from '/wasm/kodo_playground.js';
      init().then(() => {
        globalThis.__kodoWasm = { check };
      }).catch(err => {
        console.error('WASM load failed:', err);
      });
    </script>
  </body>
</html>
